flowchart TD
  %% Decode
  D0[F2 decode input: 4 bytes] --> D1[u32::from_be_bytes]
  D1 --> D2[word: u32]
  D2 --> D3["report_value = word & 0xFFFF"]
  D2 --> D4["expedited = (word >> 16) & 0x07"]
  D2 --> D5[pcid = bit19]
  D2 --> D6[retransmit_flag = bit20]
  D2 --> D7["reserved_spares = (word >> 21) & 0x1FF"]
  D3 --> DOUT[PLCW32Bit]
  D4 --> DOUT
  D5 --> DOUT
  D6 --> DOUT
  D7 --> DOUT

  %% Encode
  EOUT[PLCW32Bit] --> V["validate: expedited<=7, reserved_spares<=0x1FF"]
  V --> E1[word = 0]
  E1 --> E2["word |= report_value"]
  E2 --> E3["word |= (expedited & 0x07) << 16"]
  E3 --> E4{pcid?}
  E4 -->|yes| E4Y["word |= 1<<19"]
  E4 -->|no| E5{retransmit?}
  E4Y --> E5{retransmit?}
  E5 -->|yes| E5Y["word |= 1<<20"]
  E5 -->|no| E6["word |= (reserved_spares & 0x1FF) << 21"]
  E5Y --> E6["word |= (reserved_spares & 0x1FF) << 21"]
  E6 --> E7["word |= 1<<31 (format_id=1)"]
  E7 --> E8["word |= 1<<30 (type_id=1)"]
  E8 --> E9[u32::to_be_bytes]
  E9 --> E10[F2 encode output: 4 bytes]